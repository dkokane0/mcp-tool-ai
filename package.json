{
  "name": "mcp-tool-ai",
  "version": "1.0.0",
  "description": "Deployable Express app that exposes MCP tool servers through one gateway.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "server1": "tsx src/cli/server1.ts",
    "server2": "tsx src/cli/server2.ts",
    "ai": "tsx src/cli/ai.ts",
    "gateway": "tsx src/cli/gateway.ts",
    "all": "concurrently \"npm:server1\" \"npm:server2\" \"npm:ai\" \"npm:gateway\"",
    "ai:chat": "tsx src/cli/nvAiModel.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=384 dist/src/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^6.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "concurrently": "^8.2.2",
    "tsx": "^4.20.0",
    "typescript": "^5.5.2"
  }
}
