{
  "name": "mcp-gateway-tutorial",
  "version": "1.0.0",
  "description": "A small MCP gateway tutorial that proxies tools from two Streamable HTTP MCP servers.",
  "type": "module",
  "scripts": {
    "server1": "tsx mcp1.ts",
    "server2": "tsx mcp2.ts",
    "ai": "tsx mcp-ai.ts",
    "gateway": "tsx mcp-gateway.ts",
    "all": "concurrently \"npm:server1\" \"npm:server2\" \"npm:ai\" \"npm:gateway\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "concurrently": "^8.2.2",
    "tsx": "^4.20.0",
    "typescript": "^5.5.2"
  }
}
