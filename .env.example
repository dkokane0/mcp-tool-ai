MCP_LISTEN_HOST=127.0.0.1
MCP_PUBLIC_HOST=localhost
MCP_PATH=/mcp

MCP1_PORT=3000
MCP2_PORT=3001
MCP_AI_PORT=3002
MCP_GATEWAY_PORT=8000

MCP1_URL=http://localhost:3000/mcp
MCP2_URL=http://localhost:3001/mcp
MCP_AI_URL=http://localhost:3002/mcp
MCP_GATEWAY_SERVERS=1,2,ai

AI_PROVIDERS=nvidia
AI_DEFAULT_PROVIDER=nvidia

# NVIDIA hosted NIM uses an OpenAI-compatible /v1 API.
AI_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_NVIDIA_MODEL=openai/gpt-oss-120b
AI_NVIDIA_API_KEY=

# The server also accepts NVIDIA_* aliases for the NVIDIA provider.
# NVIDIA_API_KEY=
# NVIDIA_MODEL=openai/gpt-oss-120b
